{
  "name": "fractal-template",
  "description": "A modern Next.js template with HeroUI, Tailwind CSS, and TypeScript",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "minimumReleaseAge": 4320,
  "repository": {
    "type": "git",
    "url": "https://github.com/philogicae/fractal-template.git"
  },
  "homepage": "https://github.com/philogicae/fractal-template",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000 --turbo",
    "lint": "biome check --write app --unsafe",
    "build": "next build --turbo",
    "start": "next start -H 0.0.0.0 -p 3000",
    "upgrade": "pnpm update && pnpm prune",
    "clean": "rimraf .next && rimraf out && rimraf node_modules && pnpm install",
    "repomix": "pnpx repomix --style markdown --remove-empty-lines"
  },
  "dependencies": {
    "@heroui/react": "^3.0.4",
    "@heroui/styles": "^3.0.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "csso": "^5.0.5",
    "marked": "^18.0.3",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "terser": "^5.47.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/csso": "^5.0.4",
    "@types/node": "25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "postcss": "^8.5.14",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
