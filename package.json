{
  "name": "nextjs-template",
  "description": "A modern Next.js template with HeroUI, Tailwind CSS, and TypeScript",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/philogicae/nextjs-template.git"
  },
  "homepage": "https://github.com/philogicae/nextjs-template",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000 --turbo",
    "lint": "biome check --write app --unsafe",
    "build": "next build --turbo",
    "start": "next start -H 0.0.0.0 -p 3000",
    "upgrade": "pnpm update && pnpm prune",
    "clean": "rimraf .next && rimraf out && rimraf node_modules && pnpm install",
    "repomix": "pnpx repomix --style markdown --remove-empty-lines"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "postcss": "^8.5.13",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
