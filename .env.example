# ============================================
# Next.js Template Environment Variables
# ============================================

# ============================================
# Application Settings
# ============================================

# Node environment (development/production)
NODE_ENV=development

# Port for development server
PORT=3000

# Host for development server
HOST=0.0.0.0

# ============================================
# Analytics & Monitoring (Optional)
# ============================================

# Vercel Analytics ID (automatically set on Vercel)
# VERCEL_ANALYTICS_ID=

# ============================================
# API Keys & External Services (Optional)
# ============================================

# Example API key configuration
# API_KEY=your_api_key_here

# Database URL (if using a database)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis URL (if using Redis)
# REDIS_URL=redis://localhost:6379

# ============================================
# Feature Flags (Optional)
# ============================================

# Enable beta features
# ENABLE_BETA_FEATURES=false

# ============================================
# Build Settings
# ============================================

# Disable source maps in production
# GENERATE_SOURCEMAP=false

# Bundle analyzer (for analyzing bundle size)
# ANALYZE=true
