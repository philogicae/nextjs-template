# ============================================
# Next.js Template Environment Variables
# ============================================

# ============================================
# Docker Compose Settings
# ============================================

# Compose project name (shown in `docker compose ls`)
DOCKER_PROJECT_NAME=nextjs-template

# Container name for the app service
DOCKER_CONTAINER_NAME=nextjs-template

# Image name and tag built by `docker compose build`
DOCKER_IMAGE_NAME=nextjs-template
DOCKER_IMAGE_TAG=latest

# Host port mapped to the container's internal port 3000
DOCKER_PORT=3000

# ============================================
# Analytics & Monitoring (Optional)
# ============================================

# Vercel Analytics ID (automatically set on Vercel)
# VERCEL_ANALYTICS_ID=

# ============================================
# API Keys & External Services (Optional)
# ============================================

# Example API key configuration
# API_KEY=your_api_key_here

# Database URL (if using a database)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis URL (if using Redis)
# REDIS_URL=redis://localhost:6379

# ============================================
# Feature Flags (Optional)
# ============================================

# Enable beta features
# ENABLE_BETA_FEATURES=false

# ============================================
# Build Settings
# ============================================

# Disable source maps in production
# GENERATE_SOURCEMAP=false

# Bundle analyzer (for analyzing bundle size)
# ANALYZE=true
